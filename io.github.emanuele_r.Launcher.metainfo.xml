<component type="desktop-application">
  <id>io.github.emanuele_r.Launcher</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Launcher</name>
  <summary>Quick command bar with web search and multi-provider AI chat</summary>

  <developer id="io.github.emanuele_r">
    <name>Lehman</name>
  </developer>

  <description>
    <p>
      Launcher is a lightweight, Spotlight-style command bar that stays out of
      the way until you summon it. Type to search the web, browse in an embedded
      viewer, or chat with an AI model — all from one frameless, keyboard-driven
      window.
    </p>
    <p>Features:</p>
    <ul>
      <li>Instant web search (DuckDuckGo, Google, or Bing)</li>
      <li>Built-in browser panel</li>
      <li>AI chat with OpenAI, Claude (Anthropic), Kimi (Moonshot), OpenRouter, or any OpenAI-compatible endpoint</li>
      <li>Saved conversation history with a lateral panel</li>
      <li>Frameless, always-on-top, keyboard-driven</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.emanuele_r.Launcher.desktop</launchable>

